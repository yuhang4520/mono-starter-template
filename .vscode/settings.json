{
  "typescript.tsdk": "apps/wabash-api/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.associations": {
    "**/pages.json": "jsonc",
    "**/manifest.json": "jsonc"
  },
  "i18n-ally.localesPaths": ["apps/wabash-admin/i18n/messages"],
  "i18n-ally.keystyle": "flat",
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml"
  ]
}
